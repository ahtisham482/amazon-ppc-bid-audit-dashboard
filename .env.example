# Sentry — leave blank to disable. When set, frontend errors are reported.
# Get a DSN from https://sentry.io → Settings → Projects → Client Keys.
VITE_SENTRY_DSN=

# Plausible Analytics — leave blank to disable. Privacy-first, no cookies.
# Set this to the domain Plausible is tracking, e.g. "ppc-auditor.com".
VITE_PLAUSIBLE_DOMAIN=

# Optional: override the Plausible script URL (defaults to plausible.io).
# Use this for self-hosted instances.
# VITE_PLAUSIBLE_SCRIPT_SRC=https://plausible.example.com/js/script.js
